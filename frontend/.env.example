# Same rule: bare Supabase host, no /rest/v1 suffix, no trailing slash.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# FastAPI backend URL. Local: http://localhost:8000. Prod: https://<your-app>.onrender.com
VITE_API_URL=http://localhost:8000

# Public app URL. Local: http://localhost:5173. Prod: https://<your-app>.vercel.app
VITE_APP_URL=http://localhost:5173
