# === Supabase ===
# Bare host only. Do NOT append /rest/v1, /auth/v1, or a trailing slash.
# ✓ https://abcdefgh.supabase.co
# ✗ https://abcdefgh.supabase.co/rest/v1/
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI providers ===
OPENAI_API_KEY=
# whisper-1 (default) supports verbose_json + segment timestamps needed by the UI.
# gpt-4o-mini-transcribe is faster but lacks verbose_json support — do not use
# while the transcript view renders per-segment timestamps.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
ANTHROPIC_API_KEY=

# === URLs ===
# Local dev defaults shown. In production set to your Render and Vercel URLs.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# === Runtime ===
ENVIRONMENT=development
LOG_LEVEL=INFO
