# === Supabase ===
# Bare host only. Do NOT append /rest/v1, /auth/v1, or a trailing slash.
# ✓ https://abcdefgh.supabase.co
# ✗ https://abcdefgh.supabase.co/rest/v1/
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI providers ===
OPENAI_API_KEY=
# Default: gpt-4o-mini-transcribe (faster, cheaper, better multilingual quality).
# Returns plain text only — transcript UI renders paragraphs instead of timestamps.
# Set to whisper-1 to restore per-segment timestamp display in the transcript view.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
ANTHROPIC_API_KEY=

# === URLs ===
# Local dev defaults shown. In production set to your Render and Vercel URLs.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# === Runtime ===
ENVIRONMENT=development
LOG_LEVEL=INFO
