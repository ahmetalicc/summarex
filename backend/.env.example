# === Supabase ===
# Bare host only. Do NOT append /rest/v1, /auth/v1, or a trailing slash.
# ✓ https://abcdefgh.supabase.co
# ✗ https://abcdefgh.supabase.co/rest/v1/
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI providers ===
OPENAI_API_KEY=
# Default: whisper-1 — transcribes long audio in full (chunks internally, up to the
# 25MB file limit) and returns per-segment timestamps + duration. NOTE: gpt-4o-mini-transcribe
# truncates long recordings at its output-token cap, so it is NOT the default.
OPENAI_TRANSCRIPTION_MODEL=whisper-1
ANTHROPIC_API_KEY=

# === URLs ===
# Local dev defaults shown. In production set to your Render and Vercel URLs.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# === Runtime ===
ENVIRONMENT=development
LOG_LEVEL=INFO
