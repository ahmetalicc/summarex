# === Supabase ===
# Bare host only. Do NOT append /rest/v1, /auth/v1, or a trailing slash.
# ✓ https://abcdefgh.supabase.co
# ✗ https://abcdefgh.supabase.co/rest/v1/
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === AI providers ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === URLs ===
# Local dev defaults shown. In production set to your Render and Vercel URLs.
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# === Runtime ===
ENVIRONMENT=development
LOG_LEVEL=INFO
